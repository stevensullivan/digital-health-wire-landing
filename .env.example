# Meta Pixel ID — enables the pixel (sets _fbp/_fbc, forwarded as FBP/FBC).
# Public: exposed to the browser. Without it the pixel does not render.
NEXT_PUBLIC_META_PIXEL_ID=

# n8n webhook the server posts subscriptions to. Defaults to the production URL in code.
WEBHOOK_URL=

# Mailchimp audience this landing page subscribes people to. Defaults to fee526ecba.
MAILCHIMP_AUDIENCE_ID=
